    "@vitejs/plugin-react": "6.0.1",
    "storybook": "10.3.5",
    "typescript": "5.9.3",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "@storybook/addon-docs": "10.3.5"
  }
