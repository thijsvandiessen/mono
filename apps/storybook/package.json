    "@storybook/react-vite": "8.6.12",
    "@storybook/test": "8.6.12",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "storybook": "8.6.12",
