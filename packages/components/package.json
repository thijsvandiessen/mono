{
  "name": "@mono/components",
  "version": "1.0.0",
  "private": true,
  "description": "components",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run build:scss && tsc",
    "build:scss": "cpx \"src/**/*.scss\" dist",
    "dev": "cpx \"src/**/*.scss\" dist --watch && tsc --watch",
    "lint": "pnpm run lint:js && pnpm run lint:styles",
    "lint:js": "eslint",
    "lint:styles": "oxfmt . --write",
    "test": "vitest run -c ./vitest.config.ts"
  },
  "dependencies": {
    "@mono/data": "workspace:*",
    "@mono/hooks": "workspace:*",
    "@mono/next-js": "workspace:*",
    "@mono/search-site": "workspace:*",
    "@mono/utils": "workspace:*",
    "@react-google-maps/api": "2.20.8",
    "classnames": "2.5.1",
    "datocms-structured-text-utils": "6.0.0",
    "react": "19.2.7",
    "react-datocms": "8.0.3",
    "react-dom": "19.2.7",
    "urql": "5.0.2"
  },
  "devDependencies": {
    "@mono/eslint-config": "workspace:*",
    "@mono/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cpx2": "9.0.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.2",
    "eslint-plugin-testing-library": "7.16.2",
    "jsdom": "29.1.1",
    "sass": "1.99.0",
    "turbo": "2.9.16",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
