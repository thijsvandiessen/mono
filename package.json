{
  "name": "mono-vandiessen",
  "version": "1.0.24",
  "private": true,
  "description": "Monorepo for small websites",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "e2e"
  ],
  "scripts": {
    "build": "tsc --build && pnpm run -r build",
    "codegen": "pnpm -r download-schema && pnpm -r codegen",
    "dev": "pnpm -r --parallel --stream dev",
    "e2e": "pnpm exec turbo e2e",
    "e2e:install": "pnpm --filter e2e install:browsers",
    "lint": "pnpm run -r lint",
    "test": "vitest run -c ./vitest.config.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.5.0",
    "@swc/core": "1.15.18",
    "@types/node": "25.5.0",
    "concurrently": "9.2.1",
    "dotenv": "17.3.1",
    "eslint": "9.39.2",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "turbo": "2.8.16",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
