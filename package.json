{
  "name": "mono-vandiessen",
  "version": "1.1.1",
  "private": true,
  "description": "Monorepo for small websites",
  "workspaces": [
    "packages/*",
    "apps/*",
    "e2e"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc --build && pnpm run -r build",
    "codegen": "pnpm --filter @mono/data... download-schema && pnpm --filter @mono/data... codegen",
    "dev": "pnpm -r --parallel --stream dev",
    "e2e": "pnpm --filter @mono/e2e... e2e",
    "e2e:install": "pnpm --filter @mono/e2e... install:browsers",
    "lint": "pnpm run -r lint",
    "format": "oxfmt --write",
    "test": "vitest run -c ./vitest.config.ts",
    "test:coverage": "vitest run -c ./vitest.config.ts --coverage"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@swc/core": "1.15.26",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.8",
    "concurrently": "10.0.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.2",
    "oxfmt": "0.53.0",
    "ts-node": "10.9.2",
    "turbo": "2.9.16",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.4"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
